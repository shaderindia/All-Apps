# Custom headers for Cloudflare Pages & Netlify

# Cache stylesheet for 1 year (31,536,000 seconds)
/css/*
  Cache-Control: public, max-age=31536000, immutable

# Cache screenshots and thumbnails for 1 year
/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

# Cache logo assets for 1 year
/passport-logo.jpg
  Cache-Control: public, max-age=31536000, immutable

/passport-logo.webp
  Cache-Control: public, max-age=31536000, immutable

/cubes.png
  Cache-Control: public, max-age=31536000, immutable

/black-linen.png
  Cache-Control: public, max-age=31536000, immutable

/photopassportsizepro/banner.jpg
  Cache-Control: public, max-age=31536000, immutable

/cvbanao/banner.png
  Cache-Control: public, max-age=31536000, immutable

/berofchat/banner.jpg
  Cache-Control: public, max-age=31536000, immutable

# Cache local font files for 1 year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
