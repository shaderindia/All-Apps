<script>
  function n(v){ const num = Number(v); return Number.isFinite(num) ? num : NaN; }

  function fmt(num){
    if(!Number.isFinite(num)) return "NaN";
    const s = String(num);
    if(s.includes("e") || s.includes("E")) return num.toFixed(6).replace(/\.?0+$/,"");
    return s;
  }

  function padO(num){
    return "O" + String(num).padStart(4,'0');
  }

  function getSpindleCode(spindleMode){
    if(spindleMode === "gear"){
      return `M141 S550 ;
M103 ;`;
    }
    return `M03 S550 ;`;
  }

  function buildOD(p){
    // OD macro format (no "(1ST)")
    return (
`%
${padO(p.progNum)} (OD INTERPOLATION);

G40 G80 G49 G90 G54 G17 ;
${getSpindleCode(p.spindleMode)}

#16=${fmt(p.x)} (X) ;
#17=${fmt(p.y)} (Y) ;

#1=${fmt(p.firstDepth)} (FIRST DEPTH) ;
#2=${fmt(p.finalDepth)} (FINAL DEPTH) ;
#30=${fmt(p.diaMake)} (DIA) (DIA TO MAKE) ;
#3=${fmt(p.doc)} (DEPTH OF CUT) ;
#4=[#30/2] ;
#5=${fmt(p.cutterR)} (CUTTER RADIUS) ;
#7=#4+#5 ;
#6=#5+#4+#8 ;
#8=${fmt(p.safety)} (SAFETY ENGAGE) ;
#12=#1 ;
#15=#1 ;

G52 X#16 Y#17 ;
G0 X0 Y0 ;
G43 G0 Z50 ;
X0 Y#6 ;
Z#15 ;
G91 G01 Y-#8 F${fmt(p.feed)} ;
IF[#1 EQ #2] GOTO 120 ;
N80 G03 X0 Y0 Z-#3 I0 J-#7 ;

G03 X0 Y0 I0 J-#7 ;
#15=[#15-#3] ;
IF[#15 GT #2] GOTO 80 ;
IF[#12 EQ 0] GOTO 130 ;
N120 G03 X0 Y0 I0 J-#7 ;
N130 G01 G40 X0 Y#8 ;
G90 G0 Z300 ;
G52 X0 Y0 ;
M5 ;
M9 ;
${p.endCode} ;
%
`
    );
  }

  function buildID(p){
    // ID macro EXACTLY like user-provided format (no safety engage, N29/N35/N36)
    return (
`%
${padO(p.progNum)} (ID INTERPOLATION);

G40 G80 G49 G90 G54 G17 ;
${getSpindleCode(p.spindleMode)}

#16=${fmt(p.x)} (X) ;
#17=${fmt(p.y)} (Y) ;

#1=${fmt(p.firstDepth)} (FIRST DEPTH) ;
#2=${fmt(p.finalDepth)} (FINAL DEPTH) ;
#30=${fmt(p.diaMake)} (DIA TO MAKE) ;
#3=${fmt(p.doc)} (DEPTH OF CUT) ;
#4=[#30/2] ;
#5=${fmt(p.cutterR)} (CUTTER RADIUS) ;
#6=#4-#5 ;
#12=#1 ;
#15=#1 ;

G52 X#16 Y#17 ;
G0 X0 Y0 ;
G43 G0 Z50 ;
Z#15 ;
G91 G01 Y#6 F${fmt(p.feed)} ;
IF[#1 EQ #2] GOTO 35 ;
N29 G03 X0 Y0 Z-#3 I0 J-#6 ;
G03 X0 Y0 I0 J-#6 ;
#15=[#15-#3] ;
IF[#15 GT #2] GOTO 29 ;
IF[#12 EQ 0] GOTO 36 ;
N35 G03 X0 Y0 I0 J-#6 ;
N36 G01 G40 X0 Y0 ;
G90 G0 Z300 ;
G52 X0 Y0 ;
M5 ;
${p.endCode} ;
%
`
    );
  }

  function validate(p){
    const errs = [];

    for(const [k,v] of Object.entries(p)){
      if(k === "mode" || k === "endCode" || k === "spindleMode") continue;
      if(!Number.isFinite(v)) errs.push(`${k} must be a number`);
    }

    if(Number.isFinite(p.progNum) && p.progNum < 0) errs.push("Program number cannot be negative");
    if(Number.isFinite(p.doc) && p.doc <= 0) errs.push("Depth of cut (#3) must be > 0");
    if(Number.isFinite(p.diaMake) && p.diaMake <= 0) errs.push("Diameter to make (#30) must be > 0");
    if(Number.isFinite(p.cutterR) && p.cutterR <= 0) errs.push("Cutter radius (#5) must be > 0");
    if(Number.isFinite(p.feed) && p.feed <= 0) errs.push("Feed must be > 0");

    if(p.mode === "ID"){
      const pathR = (p.diaMake/2) - p.cutterR; // #6
      if(Number.isFinite(pathR) && pathR <= 0){
        errs.push("ID too small for this cutter: (#30/2 - #5) must be > 0");
      }
    }

    if(Number.isFinite(p.firstDepth) && Number.isFinite(p.finalDepth)){
      if(p.finalDepth > p.firstDepth){
        errs.push("Final depth (#2) is greater than first depth (#1). If cutting down in Z-, final depth is usually <= first.");
      }
    }

    return errs;
  }

  function getParams(){
    return {
      mode: document.getElementById("mode").value,
      progNum: parseInt(document.getElementById("progNum").value, 10),
      spindleMode: document.getElementById("spindleMode").value,
      endCode: document.getElementById("endCode").value,
      x: n(document.getElementById("x").value),
      y: n(document.getElementById("y").value),
      firstDepth: n(document.getElementById("firstDepth").value),
      finalDepth: n(document.getElementById("finalDepth").value),
      doc: n(document.getElementById("doc").value),
      diaMake: n(document.getElementById("diaMake").value),
      cutterR: n(document.getElementById("cutterR").value),
      safety: n(document.getElementById("safety").value),
      feed: n(document.getElementById("feed").value)
    };
  }

  function generate(){
    const p = getParams();
    const errs = validate(p);

    // Show/hide OD safety row
    document.getElementById("odSafetyRow").style.display = (p.mode === "OD") ? "block" : "none";

    const errEl = document.getElementById("err");
    const outEl = document.getElementById("output");

    if(errs.length){
      errEl.textContent = errs.join(" • ");
      outEl.value = "";
      return;
    }
    errEl.textContent = "";
    outEl.value = (p.mode === "ID") ? buildID(p) : buildOD(p);
  }

  async function copyOut(){
    const out = document.getElementById("output").value;
    if(!out.trim()) return;
    try{
      await navigator.clipboard.writeText(out);
      const copyBtn = document.getElementById("copyBtn");
      const originalText = copyBtn.textContent;
      copyBtn.textContent = "Copied!";
      copyBtn.style.background = "#16a34a";
      copyBtn.style.color = "#fff";
      setTimeout(() => {
          copyBtn.textContent = originalText;
          copyBtn.style.background = "#e2e8f0";
          copyBtn.style.color = "#334155";
      }, 2000);
    }catch{
      const ta = document.getElementById("output");
      ta.focus(); ta.select();
      document.execCommand("copy");
    }
  }

  function downloadOut(){
    const out = document.getElementById("output").value;
    const p = getParams();
    if(!out.trim()) return;

    const blob = new Blob([out], {type:"text/plain;charset=utf-8"});
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `${p.mode}_INTERPOLATION_O${String(p.progNum).padStart(4,'0')}.txt`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  document.getElementById("generateBtn").addEventListener("click", generate);
  document.getElementById("copyBtn").addEventListener("click", copyOut);
  document.getElementById("downloadBtn").addEventListener("click", downloadOut);

  // auto-generate when switching
  document.getElementById("mode").addEventListener("change", generate);
  document.getElementById("spindleMode").addEventListener("change", generate);
  document.getElementById("endCode").addEventListener("change", generate);

  generate();
</script>
</body>
