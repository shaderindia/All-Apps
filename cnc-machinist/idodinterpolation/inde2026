    <a href="https://shader7.com" target="_blank" class="banner">⚙️ Shader7 OD / ID INTERPOLATION</a>
    <h1>OD / ID Interpolation Macro Generator</h1>

    <div class="grid">
      <div class="row">
        <label for="mode">Mode</label>
        <select id="mode">
          <option value="OD" selected>OD (Outside Diameter)</option>
          <option value="ID">ID (Inside Diameter)</option>
        </select>
        <div class="note">ID mode matches your N29/N35/N36 program.</div>
      </div>

      <div class="row">
        <label for="progNum">Program Number (O####)</label>
        <input id="progNum" type="number" step="1" value="1" />
        <div class="note">Default O0001. Example: 30 → O0030</div>
      </div>

      <div class="row">
        <label for="spindleMode">Spindle Mode</label>
        <select id="spindleMode">
          <option value="gear" selected>M141 S550 + M103 (Gear Head)</option>
          <option value="m03">M03 S550 (Standard Spindle)</option>
        </select>
      </div>

      <div class="row">
        <label for="endCode">End Program Code</label>
        <select id="endCode">
          <option value="M01">M01 (Optional Stop)</option>
          <option value="M0" selected>M0 (Program Stop)</option>
          <option value="M00">M00 (Program Stop)</option>
          <option value="M30">M30 (End of Program)</option>
        </select>
      </div>

      <div class="row">
        <label for="x">X coordinate (#16)</label>
        <input id="x" type="number" step="any" value="0" />
      </div>

      <div class="row">
        <label for="y">Y coordinate (#17)</label>
        <input id="y" type="number" step="any" value="0" />
      </div>

      <div class="row">
        <label for="firstDepth">First depth (#1)</label>
        <input id="firstDepth" type="number" step="any" value="0" />
      </div>

      <div class="row">
        <label for="finalDepth">Final depth (#2)</label>
        <input id="finalDepth" type="number" step="any" value="-0.50" />
      </div>

      <div class="row">
        <label for="doc">Depth of cut (#3)</label>
        <input id="doc" type="number" step="any" value="0.05" />
      </div>

      <div class="row">
        <label for="diaMake">Diameter to make (#30)</label>
        <input id="diaMake" type="number" step="any" value="500" />
      </div>

      <div class="row">
        <label for="cutterR">Cutter radius (#5)</label>
        <input id="cutterR" type="number" step="any" value="50" />
        <div class="note">Enter cutter <b>radius</b> (matches your ID example).</div>
      </div>

      <div class="row" id="odSafetyRow">
        <label for="safety">Safety engage (#8) (OD only)</label>
        <input id="safety" type="number" step="any" value="0" />
      </div>

      <div class="row">
        <label for="feed">Feed (F)</label>
        <input id="feed" type="number" step="any" value="1000" />
      </div>
    </div>

    <div class="actions">
      <button class="primary" id="generateBtn">Generate Program</button>
      <button class="secondary" id="copyBtn">Copy to Clipboard</button>
      <button class="secondary" id="downloadBtn">Download .txt</button>
    </div>

    <div id="err" class="error"></div>
    <textarea id="output" class="out" spellcheck="false"></textarea>

    <div class="note">
      Output starts with <b>%</b> and ends with <b>%</b>. Program header is <b>O####</b>.
      Validate on your control/simulator before cutting.
    </div>

    <div class="credits">
      &copy; <script>document.write(new Date().getFullYear())</script> SHADER7 • Developed by <a href="https://www.instagram.com/nishix_vamp" target="_blank" rel="noopener noreferrer">@nishix_vamp</a>
    </div>
