<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Circular Chamfer Macro Generator</title>

<style>
:root{
  --bg:#0f172a;
  --panel:#111827;
  --panel2:#1f2937;
  --border:#374151;
  --text:#ffffff;
  --muted:#9ca3af;
  --green:#22c55e;
  --indigo:#4f46e5;
  --indigo-hover:#4338ca;
  --success:#16a34a;
  --success-hover:#15803d;
  --gray:#374151;
  --gray-hover:#4b5563;
}

*{
  box-sizing:border-box;
}

body{
  margin:0;
  font-family:Arial, sans-serif;
  background:linear-gradient(180deg,#111827 0%,#0f172a 100%);
  color:var(--text);
  padding:24px;
}

.container{
  max-width:1100px;
  margin:auto;
}

h1{
  margin:0 0 10px 0;
  font-size:clamp(28px,4vw,40px);
}

.subtitle{
  color:var(--muted);
  margin-bottom:24px;
}

.layout{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
}

.panel{
  background:rgba(17,24,39,.96);
  border:1px solid var(--border);
  border-radius:16px;
  padding:20px;
  box-shadow:0 12px 30px rgba(0,0,0,.25);
}

.panel h2{
  margin:0 0 16px 0;
  font-size:18px;
}

.form-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px 16px;
}

.field{
  display:flex;
  flex-direction:column;
}

.field.full{
  grid-column:1 / -1;
}

label{
  margin-bottom:6px;
  font-size:14px;
  color:#d1d5db;
  font-weight:600;
}

input, select{
  width:100%;
  padding:12px 14px;
  background:var(--panel2);
  border:1px solid var(--border);
  border-radius:10px;
  color:var(--text);
  font-size:15px;
  outline:none;
}

input:focus, select:focus{
  border-color:#6366f1;
  box-shadow:0 0 0 3px rgba(99,102,241,.18);
}

.select-wrap{
  position:relative;
}

.select-wrap select{
  appearance:none;
  -webkit-appearance:none;
  -moz-appearance:none;
  padding-right:42px;
  cursor:pointer;
}

.select-wrap::after{
  content:"▼";
  position:absolute;
  right:14px;
  top:50%;
  transform:translateY(-50%);
  pointer-events:none;
  color:var(--muted);
  font-size:12px;
}

.actions{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top:18px;
}

button{
  padding:12px 18px;
  border:none;
  border-radius:10px;
  font-weight:bold;
  cursor:pointer;
  color:white;
  font-size:14px;
}

.generate{background:var(--indigo);}
.generate:hover{background:var(--indigo-hover);}

.download{background:var(--success);}
.download:hover{background:var(--success-hover);}

.copy{background:var(--gray);}
.copy:hover{background:var(--gray-hover);}

.output-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
  margin-bottom:12px;
}

.status{
  color:var(--muted);
  font-size:13px;
}

.notice{
  margin-top:12px;
  color:#cbd5e1;
  font-size:12px;
}

pre{
  background:#000;
  color:var(--green);
  padding:20px;
  border-radius:12px;
  border:1px solid #1f2937;
  margin-top:0;
  white-space:pre-wrap;
  word-break:break-word;
  min-height:650px;
  overflow:auto;
  font-size:14px;
  line-height:1.5;
}

@media (max-width: 900px){
  .layout{
    grid-template-columns:1fr;
  }

  .form-grid{
    grid-template-columns:1fr;
  }

  pre{
    min-height:360px;
  }
}

@media (max-width: 520px){
  body{
    padding:16px;
  }

  .panel{
    padding:16px;
  }

  button{
    width:100%;
  }
}
</style>
</head>

<body>

<div class="container">
  <h1>Circular Chamfer Macro Generator</h1>
  <div class="subtitle">Ready-to-use CNC macro generator with fixed dropdown, responsive layout, and live G-code update.</div>

  <div class="layout">
    <div class="panel">
      <h2>Macro Settings</h2>

      <div class="form-grid">
        <div class="field">
          <label for="start-depth">Start Depth (#1)</label>
          <input id="start-depth" type="number" step="any" value="1">
        </div>

        <div class="field">
          <label for="final-depth">Final Depth (#2)</label>
          <input id="final-depth" type="number" step="any" value="-15">
        </div>

        <div class="field">
          <label for="diameter">Base Diameter (#3)</label>
          <input id="diameter" type="number" step="any" value="51">
        </div>

        <div class="field">
          <label for="angle">Chamfer Angle (#4)</label>
          <input id="angle" type="number" step="any" value="45">
        </div>

        <div class="field">
          <label for="z-step">Z Step (#6)</label>
          <input id="z-step" type="number" step="any" value="0.5">
        </div>

        <div class="field">
          <label for="d-reg">Tool Offset Register (#7)</label>
          <input id="d-reg" type="number" step="1" value="11">
        </div>

        <div class="field">
          <label for="f-cut">Cut Feedrate</label>
          <input id="f-cut" type="number" step="any" value="500">
        </div>

        <div class="field">
          <label for="f-retract">Retract Feedrate</label>
          <input id="f-retract" type="number" step="any" value="1000">
        </div>

        <div class="field">
          <label for="safe-z">Safe Z</label>
          <input id="safe-z" type="number" step="any" value="200">
        </div>

        <div class="field">
          <label for="prog-num">Program Number</label>
          <input id="prog-num" type="number" step="1" value="6999">
        </div>

        <div class="field full">
          <label for="spindle">Spindle Command</label>
          <div class="select-wrap">
            <select id="spindle">
              <option value="M141 S500; M103;">M141 S500; M103;</option>
              <option value="M03 S500;">M03 S500;</option>
            </select>
          </div>
        </div>
      </div>

      <div class="actions">
        <button class="generate" onclick="generate()">Generate Macro</button>
        <button class="download" onclick="downloadFile()">Download .NC</button>
        <button class="copy" onclick="copyCode()">Copy</button>
      </div>

      <div class="notice">
        Verify the output on your machine control before running production code.
      </div>
    </div>

    <div class="panel">
      <div class="output-header">
        <h2 style="margin:0;">Generated Code</h2>
        <div class="status" id="status">Ready</div>
      </div>
      <pre id="output"></pre>
    </div>
  </div>
</div>

<script>
function val(id){
  return parseFloat(document.getElementById(id).value) || 0;
}

function setStatus(msg){
  document.getElementById("status").textContent = msg;
}

function round3(n){
  return Math.round((n + Number.EPSILON) * 1000) / 1000;
}

function generate(){
  const prog = String(document.getElementById("prog-num").value || "0").padStart(4, "0");

  let z1 = val("start-depth");
  const z2 = val("final-depth");
  const dia = val("diameter");
  const ang = val("angle");
  const zStep = val("z-step");
  const dReg = val("d-reg");
  const fCut = val("f-cut");
  const fRet = val("f-retract");
  const safeZ = val("safe-z");
  const spindle = document.getElementById("spindle").value;

  if(zStep <= 0){
    document.getElementById("output").textContent = "(ERROR: Z STEP MUST BE GREATER THAN 0)";
    setStatus("Fix Z step");
    return;
  }

  if(dia <= 0){
    document.getElementById("output").textContent = "(ERROR: BASE DIAMETER MUST BE GREATER THAN 0)";
    setStatus("Fix diameter");
    return;
  }

  if(z1 <= z2){
    document.getElementById("output").textContent = "(ERROR: START DEPTH MUST BE GREATER THAN FINAL DEPTH FOR THIS MACRO)";
    setStatus("Fix depths");
    return;
  }

  let gcode = "";

  gcode += `%\n`;
  gcode += `O${prog} (CIRCULAR CHAMFER MACRO)\n`;
  gcode += `G40 G0 G90 G54 G17;\n`;
  gcode += `${spindle}\n`;

  gcode += `#1=${round3(z1)} (FIRST Z ENTRY)\n`;
  gcode += `#2=${round3(z2)} (FINAL Z DEPTH)\n`;
  gcode += `#3=${round3(dia)} (BASE DIAMETER)\n`;
  gcode += `#4=${round3(ang)} (CHAMFER ANGLE)\n`;
  gcode += `#6=${round3(zStep)} (Z STEP PER PASS)\n`;
  gcode += `#7=${round3(dReg)} (TOOL OFFSET REGISTER)\n`;

  gcode += `G90 G0 X0 Y0 (MOVE TO CENTER)\n`;
  gcode += `G0 Z[#1+2.] (SAFE APPROACH)\n`;

  gcode += `WHILE[#1 GT #2] DO1\n`;
  gcode += `#9=ABS[#1-#2] (DISTANCE TO BASE)\n`;
  gcode += `#5=[[#3/2]+[#9*TAN[#4]]] (CURRENT RADIUS)\n`;
  gcode += `G90 G1 Z#1 F${round3(fCut)}\n`;
  gcode += `G91 G1 G41 D#7 X#5 F${round3(fCut)}\n`;
  gcode += `G03 X0 Y0 I-#5 J0\n`;
  gcode += `G1 G40 X-#5 F${round3(fRet)}\n`;
  gcode += `#1=#1-#6 (NEXT PASS)\n`;
  gcode += `END1\n`;

  gcode += `(FINAL PASS)\n`;
  gcode += `#1=#2\n`;
  gcode += `#5=[#3/2]\n`;
  gcode += `G90 G1 Z#1 F${round3(fCut)}\n`;
  gcode += `G91 G1 G41 D#7 X#5 F${round3(fCut)}\n`;
  gcode += `G03 X0 Y0 I-#5 J0\n`;
  gcode += `G1 G40 X-#5 F${round3(fRet)}\n`;

  gcode += `G90 G0 Z${round3(safeZ)} (SAFE RETRACT)\n`;
  gcode += `M0\n`;
  gcode += `%\n`;

  document.getElementById("output").textContent = gcode;
  setStatus("Macro generated");
}

function copyCode(){
  const text = document.getElementById("output").textContent;

  if(!text.trim()){
    setStatus("Nothing to copy");
    return;
  }

  navigator.clipboard.writeText(text)
    .then(() => setStatus("Copied to clipboard"))
    .catch(() => setStatus("Copy failed"));
}

function downloadFile(){
  const text = document.getElementById("output").textContent;
  const prog = document.getElementById("prog-num").value || "0000";

  if(!text.trim()){
    setStatus("Generate code first");
    return;
  }

  const blob = new Blob([text], {type:"text/plain"});
  const url = URL.createObjectURL(blob);

  const a = document.createElement("a");
  a.href = url;
  a.download = `O${prog}.nc`;
  document.body.appendChild(a);
  a.click();
  a.remove();

  URL.revokeObjectURL(url);
  setStatus("NC file downloaded");
}

function enableLiveUpdate(){
  const inputs = document.querySelectorAll("input, select");

  inputs.forEach(el => {
    el.addEventListener("input", generate);
    el.addEventListener("change", generate);
  });
}

window.addEventListener("load", () => {
  enableLiveUpdate();
  generate();
});
</script>

</body>
</html>
