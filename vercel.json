{
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/screenshots/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(passport-logo.jpg|passport-logo.webp|cubes.png|black-linen.png|photopassportsizepro/banner.jpg|photopassportsizepro/banner.webp|cvbanao/banner.png|cvbanao/banner.webp|berofchat/banner.jpg|berofchat/banner.webp|cnc-machinist/banner.jpg|cnc-machinist/banner.webp|photocompressor/banner.jpg|photocompressor/banner.webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
